# ── Credenciais de acesso ao TMS (login via automação) ────────────────────────
TMS_EMAIL=
TMS_PASSWORD=

# ── Token da API do TMS ───────────────────────────────────────────────────────
# Gere em: Cadastros > Usuários > Aba API > Editar usuário API > Gerar token
TMS_API_TOKEN=

# ── Endereço do TMS ───────────────────────────────────────────────────────────
TMS_HOST=mandalog.eslcloud.com.br

# ── Sessão persistida ─────────────────────────────────────────────────────────
SESSION_FILE=./data/session.json

# ── Porta do servidor ─────────────────────────────────────────────────────────
PORT=8000

# ── Modo headless (true para produção, false para debug local) ─────────────────
HEADLESS=true

# ── Delay entre ações em ms (0 para produção, 600 para debug local) ────────────
SLOW_MO=0
